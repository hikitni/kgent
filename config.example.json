{
  "watch_paths": [
    "./"
  ],
  "ignore_dirs": [
    ".git",
    "node_modules",
    "__pycache__",
    ".daily_reporter",
    "reports"
  ],
  "ignore_suffixes": [
    ".log",
    ".tmp",
    ".swp",
    ".pyc"
  ],
  "ignore_patterns": [
    "\\.idea\\\\",
    "\\.vscode\\\\"
  ],
  "snapshot_root": ".daily_reporter",
  "output_root": "reports",
  "auto_snapshot_times": ["06:00", "18:00"],
  "max_file_size_kb": 1024,

  "_ai_comment": "AI 日报配置：ai_provider 支持 disabled / zhipuai / openai / ollama；ai_prompt_template 为应求 prompt 模板文件路径",
  "ai_prompt_template": "ai_report_prompt.md",
  "ai_provider": "disabled",
  "ai_model": "",
  "ai_api_key": "",
  "ai_base_url": "",

  "_examples": {
    "智谱GLM": {
      "ai_provider": "zhipuai",
      "ai_model": "glm-4",
      "ai_api_key": "your-zhipuai-key",
      "ai_base_url": ""
    },
    "OpenAI": {
      "ai_provider": "openai",
      "ai_model": "gpt-4o",
      "ai_api_key": "sk-...",
      "ai_base_url": ""
    },
    "DeepSeek": {
      "ai_provider": "openai",
      "ai_model": "deepseek-chat",
      "ai_api_key": "your-deepseek-key",
      "ai_base_url": "https://api.deepseek.com/v1"
    },
    "Moonshot-Kimi": {
      "ai_provider": "openai",
      "ai_model": "moonshot-v1-8k",
      "ai_api_key": "your-moonshot-key",
      "ai_base_url": "https://api.moonshot.cn/v1"
    },
    "Ollama-local": {
      "ai_provider": "ollama",
      "ai_model": "qwen2.5:7b",
      "ai_api_key": "",
      "ai_base_url": "http://localhost:11434"
    }
  }
}
